{
  "pipelineId": "use_cases",
  "enabled": true,
  "description": "Production enterprise AI use-case scout pipeline.",
  "sourceIds": [
    "openai",
    "microsoft_customers",
    "google_cloud_customers",
    "anthropic",
    "aws_case_studies",
    "consulting_and_business_press"
  ],
  "collectionMethods": [
    {
      "id": "open_web_search",
      "collectorId": "brave_web_search_collector",
      "enabled": true,
      "queries": [
        "site:openai.com OR site:microsoft.com OR site:cloud.google.com OR site:aws.amazon.com enterprise AI customer story workflow production outcome",
        "site:mckinsey.com OR site:deloitte.com OR site:bcg.com OR site:pwc.com OR site:accenture.com generative AI enterprise case study workflow ROI",
        "\"enterprise AI\" \"customer story\" workflow production measurable outcome",
        "\"AI agents\" enterprise \"rolled out\" workflow deployment business outcome",
        "\"AI agent\" customer support enterprise deployed workflow metric"
      ]
    }
  ],
  "contentFetchPolicy": {
    "enabled": true,
    "fetcherId": "url_text_fetcher",
    "fetchForTopN": 20,
    "maxChars": 16000,
    "maxResponseBytes": 8000000,
    "preferFetchedContent": true
  },
  "structuredExtractorId": "enterprise_use_case_extractor",
  "selectorId": "enterprise_use_case_selector",
  "rendererId": "enterprise_use_case_markdown_renderer",
  "output": {
    "format": "markdown",
    "directory": "digests/use-cases",
    "filenameTemplate": "{date}.md",
    "artifactWriterId": "filesystem_artifact_writer"
  },
  "limits": {
    "maxCandidates": 20,
    "maxSearchQueries": 5,
    "maxSearchResultsPerQuery": 20,
    "maxCandidatesForExtraction": 20,
    "maxResults": 10,
    "maxUseCasesPerRun": 10,
    "minConfidenceScore": 3,
    "maxPerIndustry": 3,
    "maxPerSource": 3,
    "extractionMaxContentChars": 6000,
    "verificationBatchSize": 5,
    "verificationCandidateMultiplier": 2,
    "maxVerificationLinks": 0,
    "verificationMaxChars": 8000,
    "verificationPromptLinkedMaxChars": 1500,
    "verificationPromptSourceMaxChars": 5000,
    "minVerificationConfidenceScore": 3
  },
  "settings": {
    "verification": {
      "enabled": true
    }
  },
  "execution": {
    "collectionConcurrency": 2,
    "contentFetchConcurrency": 5,
    "structuredExtractionConcurrency": 1
  },
  "failurePolicy": {
    "failFast": false,
    "continueOnSourceFailure": true,
    "continueOnContentFetchFailure": true,
    "continueOnStructuredExtractionFailure": true,
    "minItemsRequiredForSuccess": 1
  }
}
