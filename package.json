{
  "name": "birbal",
  "version": "1.0.0",
  "description": "A minimal TypeScript harness for experimenting with local LLM agents and basic tools.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "daily": "tsx src/daily/run.ts",
    "use-cases": "tsx src/use-cases/run.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "LOG_LEVEL=silent tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run format:check && npm run typecheck && npm test"
  },
  "keywords": [
    "agent",
    "harness",
    "AI",
    "local-llm",
    "tools"
  ],
  "author": "Gautam Dhameja",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.8.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.8.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
